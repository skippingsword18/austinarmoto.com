---
interface Props {
  tags: string;
  title: string;
  description: string;
  href?: string;
}

const { tags, title, description, href } = Astro.props;
---

<article class="group rounded-2xl border border-slate-800 bg-slate-900/50 p-6 transition hover:-translate-y-1 hover:border-blue-500/50 hover:bg-slate-900">
  <p class="text-sm text-blue-400 mb-3">{tags}</p>

  {href ? (
    <a href={href} class="block">
      <h3 class="text-xl font-semibold mb-3 group-hover:text-blue-400">{title}</h3>
    </a>
  ) : (
    <h3 class="text-xl font-semibold mb-3">{title}</h3>
  )}

  <p class="text-slate-400">{description}</p>
</article>
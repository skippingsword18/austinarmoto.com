---
const skills = [
  "Automation",
  "Infrastructure",
  "Robotics Systems",
  "Cloud Platforms",
  "Python",
  "JavaScript",
  "AWS",
  "Docker",
];
---

<section id="focus" class="max-w-6xl mx-auto px-6 py-16">
  <h2 class="text-3xl font-bold mb-8">Technical Focus</h2>

  <div class="grid md:grid-cols-4 gap-4">
    {skills.map((skill) => (
      <div class="rounded-lg border border-slate-800 px-4 py-3 text-slate-300">
        {skill}
      </div>
    ))}
  </div>
</section>
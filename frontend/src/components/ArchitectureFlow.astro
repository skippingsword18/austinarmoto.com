---
const steps = [
  "Jira Ticket",
  "Webhook",
  "Validation",
  "Lambda Worker",
  "S3 Storage",
  "CloudWatch",
  "Jira Update",
];
---

<section class="max-w-6xl mx-auto px-6 py-20">
  <p class="text-blue-400 font-medium mb-4">Featured System</p>

  <h2 class="text-4xl font-bold mb-6">
    Event-driven automation for operational data processing.
  </h2>

  <p class="max-w-3xl text-slate-400 text-lg mb-10">
    A production workflow platform that connects Jira, AWS infrastructure,
    backend processing, validation, monitoring, and operational handoff.
  </p>

  <div class="overflow-x-auto rounded-2xl border border-slate-800 bg-slate-950/70 p-6">
    <div class="flex min-w-max items-center gap-3 font-mono text-sm">
      {steps.map((step, index) => (
        <>
          <div class="rounded-lg border border-slate-700 bg-slate-900 px-4 py-3 text-slate-200">
            {step}
          </div>

          {index < steps.length - 1 && (
            <div class="text-blue-400">→</div>
          )}
        </>
      ))}
    </div>
  </div>
</section>
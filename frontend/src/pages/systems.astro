---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Systems | Austin Armoto">
  <Navbar />

  <main class="max-w-6xl mx-auto px-6 py-24">
    <p class="text-sm uppercase tracking-[0.3em] text-blue-400 mb-6">
      Systems
    </p>

    <h1 class="max-w-4xl text-5xl md:text-7xl font-bold tracking-tight leading-tight mb-8">
      Systems I’ve designed, built, and operated.
    </h1>

    <p class="max-w-3xl text-slate-400 text-lg leading-8 mb-20">
      Selected work across automation platforms, cloud infrastructure,
      calibration tooling, operational workflows, and hardware-adjacent systems.
    </p>

    <section class="space-y-16">
      <a
        href="/systems/automated-data-platform"
        class="block border-b border-slate-800 pb-16 group"
      >
        <p class="text-blue-400 mb-4">
          AWS • Jira • Lambda • S3 • CDK • CloudWatch
        </p>

        <div class="flex flex-col lg:flex-row lg:justify-between gap-6">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold mb-4 group-hover:text-blue-400 transition">
              Automated Data Processing Platform
            </h2>

            <p class="max-w-2xl text-slate-300 leading-7">
              Designed and implemented an event-driven workflow automation system
              integrating Jira workflows, AWS infrastructure, backend processing,
              validation, monitoring, and operational handoff.
            </p>
          </div>

          <div class="lg:text-right">
            <div class="text-4xl font-bold text-blue-400">30 min</div>
            <div class="text-slate-500">Processing Time</div>
          </div>
        </div>
      </a>

      <article class="border-b border-slate-800 pb-16">
        <p class="text-blue-400 mb-4">
          Python • Calibration • Robotics • Testing
        </p>

        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Calibration & Validation Tooling
        </h2>

        <p class="max-w-2xl text-slate-300 leading-7">
          Built and maintained tooling for camera calibration and magnetometer
          validation workflows supporting autonomous systems, hardware revisions,
          testing, and regression prevention.
        </p>
      </article>

      <article>
        <p class="text-blue-400 mb-4">
          Salesforce • AWS • Automation • Email Relay
        </p>

        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Operations Workflow Platform
        </h2>

        <p class="max-w-2xl text-slate-300 leading-7">
          Managed Salesforce objects, flows, account configuration, and
          AWS-backed encrypted email relay infrastructure supporting operational workflows.
        </p>
      </article>
    </section>
  </main>

  <Footer />
</Layout>
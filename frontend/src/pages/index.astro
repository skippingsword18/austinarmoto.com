---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import SystemCard from "../components/SystemCard.astro";
import TechnicalFocus from "../components/TechnicalFocus.astro";
import Contact from "../components/Contact.astro";
---

<Layout title="Austin Armoto | System Developer">
  <Navbar />
  <main class="min-h-screen">
    <Hero />

    <section id="systems" class="max-w-6xl mx-auto px-6 py-16">
      <h2 class="text-3xl font-bold mb-8">Featured Systems</h2>

      <div class="grid md:grid-cols-3 gap-6">
        <SystemCard
          tags="AWS • Jira • Lambda • S3 • CDK"
          title="Automated Data Processing Platform"
          description="Designed an event-driven workflow system that reduced operational data processing from multiple days to roughly 30 minutes."
        />

        <SystemCard
          tags="Python • Calibration • Robotics"
          title="Calibration & Validation Tooling"
          description="Built and maintained tooling for camera and magnetometer calibration workflows supporting autonomous vehicle data collection."
        />

        <SystemCard
          tags="Salesforce • AWS • Automation"
          title="Operations Workflow Platform"
          description="Managed Salesforce workflows, objects, email relay infrastructure, and automation supporting operational teams."
        />
      </div>
    </section>

    <TechnicalFocus />
    <Contact />
  </main>
</Layout>
---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Experience from "../components/Experience.astro";
import Direction from "../components/Direction.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Austin Armoto | System Developer">
  <Navbar />

  <main class="min-h-screen">
    <Hero />

    <About />

    <Experience />

    <section id="systems" class="max-w-6xl mx-auto px-6 py-24">
      <p class="text-sm uppercase tracking-[0.3em] text-blue-400 mb-6">
        Selected Systems
      </p>

      <div class="space-y-12">
        <a
          href="/systems/automated-data-platform"
          class="block border-b border-slate-800 pb-12 group"
        >
          <div class="flex flex-col lg:flex-row lg:justify-between gap-6">
            <div>
              <h2 class="text-3xl md:text-4xl font-bold mb-4 group-hover:text-blue-400 transition">
                Automated Data Processing Platform
              </h2>

              <p class="max-w-2xl text-slate-300">
                Designed and implemented an event-driven workflow platform
                integrating Jira, AWS infrastructure, backend processing,
                validation, monitoring, and operational automation.
              </p>
            </div>

            <div class="lg:text-right">
              <div class="text-4xl font-bold text-blue-400">30 min</div>
              <div class="text-slate-500">Processing Time</div>
            </div>
          </div>
        </a>

        <div class="border-b border-slate-800 pb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">
            Calibration & Validation Tooling
          </h2>

          <p class="max-w-2xl text-slate-300">
            Built and maintained tooling supporting camera calibration,
            magnetometer validation, hardware revisions, testing,
            and regression prevention for autonomous systems.
          </p>
        </div>

        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4">
            Operations Workflow Platform
          </h2>

          <p class="max-w-2xl text-slate-300">
            Managed Salesforce workflows, custom objects,
            email relay infrastructure, and operational automation
            supporting engineering and operations teams.
          </p>
        </div>
      </div>
    </section>

    <Direction />

    <Contact />
  </main>

  <Footer />
</Layout>
---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Austin Armoto | System Developer">
  <main class="min-h-screen">
    <section class="max-w-6xl mx-auto px-6 py-24">
      <p class="text-blue-400 font-medium mb-4">
        System Developer
      </p>

      <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6">
        Building automation systems that connect software, infrastructure, and real-world operations.
      </h1>

      <p class="max-w-3xl text-lg text-slate-300 mb-10">
        I design and maintain production systems, data pipelines, calibration workflows,
        and operational tooling across cloud infrastructure, hardware-adjacent systems,
        and engineering operations.
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="#systems" class="rounded-lg bg-blue-600 px-6 py-3 font-medium hover:bg-blue-700">
          View Systems
        </a>

        <a href="#contact" class="rounded-lg border border-slate-700 px-6 py-3 font-medium hover:bg-slate-900">
          Contact
        </a>
      </div>
    </section>

    <section id="systems" class="max-w-6xl mx-auto px-6 py-16">
      <h2 class="text-3xl font-bold mb-8">Featured Systems</h2>

      <div class="grid md:grid-cols-3 gap-6">
        <article class="rounded-xl border border-slate-800 bg-slate-900/40 p-6">
          <p class="text-sm text-blue-400 mb-3">AWS • Jira • Lambda • S3 • CDK</p>
          <h3 class="text-xl font-semibold mb-3">Automated Data Processing Platform</h3>
          <p class="text-slate-400">
            Designed an event-driven workflow system that reduced operational data
            processing from multiple days to roughly 30 minutes.
          </p>
        </article>

        <article class="rounded-xl border border-slate-800 bg-slate-900/40 p-6">
          <p class="text-sm text-blue-400 mb-3">Python • Calibration • Robotics</p>
          <h3 class="text-xl font-semibold mb-3">Calibration & Validation Tooling</h3>
          <p class="text-slate-400">
            Built and maintained tooling for camera and magnetometer calibration workflows
            supporting autonomous vehicle data collection.
          </p>
        </article>

        <article class="rounded-xl border border-slate-800 bg-slate-900/40 p-6">
          <p class="text-sm text-blue-400 mb-3">Salesforce • AWS • Automation</p>
          <h3 class="text-xl font-semibold mb-3">Operations Workflow Platform</h3>
          <p class="text-slate-400">
            Managed Salesforce workflows, objects, email relay infrastructure, and
            automation supporting operational teams.
          </p>
        </article>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 py-16">
      <h2 class="text-3xl font-bold mb-8">Technical Focus</h2>

      <div class="grid md:grid-cols-4 gap-4">
        {["Automation", "Infrastructure", "Robotics Systems", "Cloud Platforms", "Python", "JavaScript", "AWS", "Docker"].map((skill) => (
          <div class="rounded-lg border border-slate-800 px-4 py-3 text-slate-300">
            {skill}
          </div>
        ))}
      </div>
    </section>

    <section id="contact" class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-3xl font-bold mb-4">Let’s connect</h2>
      <p class="text-slate-400 mb-6">
        Interested in automation, robotics, AI systems, infrastructure, and immersive technology.
      </p>

      <a href="mailto:austinarmoto@yahoo.com" class="text-blue-400 hover:text-blue-300">
        austinarmoto@yahoo.com
      </a>
    </section>
  </main>
</Layout>
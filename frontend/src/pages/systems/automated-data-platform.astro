---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Automated Data Processing Platform | Austin Armoto">
  <Navbar />

  <main class="max-w-5xl mx-auto px-6 py-24">
    <a href="/systems" class="text-slate-500 hover:text-white text-sm">
      ← Back to systems
    </a>

    <p class="text-sm uppercase tracking-[0.3em] text-blue-400 mt-12 mb-6">
      Case Study
    </p>

    <h1 class="text-5xl md:text-7xl font-bold tracking-tight leading-tight mb-8">
      Automated Data Processing Platform
    </h1>

    <p class="max-w-3xl text-xl text-slate-300 leading-8 mb-16">
      An event-driven workflow system that reduced operational processing time
      from multiple days to roughly 30 minutes.
    </p>

    <section class="grid md:grid-cols-3 gap-6 mb-20">
      <div>
        <p class="text-4xl font-bold text-blue-400">30 min</p>
        <p class="text-slate-500">Processing time</p>
      </div>

      <div>
        <p class="text-4xl font-bold text-blue-400">10+</p>
        <p class="text-slate-500">Datasets weekly</p>
      </div>

      <div>
        <p class="text-4xl font-bold text-blue-400">7+</p>
        <p class="text-slate-500">Months in production</p>
      </div>
    </section>

    <section class="space-y-16">
      <div>
        <h2 class="text-3xl font-bold mb-4">Problem</h2>
        <p class="text-slate-300 leading-8">
          Operational teams were spending multiple days processing perception
          and transit-phase datasets. The workflow required manual intervention,
          engineering support, validation, handoffs, and status tracking across
          multiple systems.
        </p>
      </div>

      <div>
        <h2 class="text-3xl font-bold mb-4">Solution</h2>
        <p class="text-slate-300 leading-8">
          Designed and implemented an event-driven automation platform integrating
          Jira workflows, AWS Lambda, S3, CDK-managed infrastructure, VPC resources,
          IAM configuration, CloudWatch monitoring, backend processing services,
          and automated workflow validation.
        </p>
      </div>

      <div>
        <h2 class="text-3xl font-bold mb-4">Workflow</h2>

        <div class="rounded-2xl border border-slate-800 bg-slate-950/70 p-6 font-mono text-slate-300 overflow-x-auto">
          Jira Ticket → Webhook → Validation → Processing Worker → S3 → CloudWatch → Jira Status Update
        </div>
      </div>

      <div>
        <h2 class="text-3xl font-bold mb-4">Ownership</h2>

        <ul class="grid md:grid-cols-2 gap-3 text-slate-300">
          <li>Requirements gathering</li>
          <li>Architecture design</li>
          <li>Python service development</li>
          <li>AWS CDK infrastructure</li>
          <li>Lambda deployment</li>
          <li>VPC and IAM configuration</li>
          <li>S3 lifecycle configuration</li>
          <li>Security review</li>
          <li>CloudWatch monitoring</li>
          <li>Production maintenance</li>
          <li>Documentation</li>
          <li>Operational handoff</li>
        </ul>
      </div>
    </section>
  </main>

  <Footer />
</Layout>